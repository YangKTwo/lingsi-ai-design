# ==========================================
# 灵思AI设计工作台 — 环境变量配置
# 复制此文件为 .env 并填入真实值
# ==========================================

# --- LLM 大语言模型 ---
# 支持 OpenAI 兼容接口的任何模型（千问/DeepSeek/GPT 等）
LLM_API_KEY=sk-your-key-here
LLM_MODEL=qwen-turbo
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 常用模型参考：
# 千问（国内）：LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-turbo
# DeepSeek：    LLM_BASE_URL=https://api.deepseek.com/v1                      LLM_MODEL=deepseek-chat
# OpenAI：      LLM_BASE_URL=https://api.openai.com/v1                        LLM_MODEL=gpt-4o-mini

# --- Embedding 向量化 ---
EMBEDDING_MODEL=text-embedding-v2

# --- Coze 扣子 ---
COZE_API_KEY=your-coze-api-key
COZE_BOT_ID=your-bot-id

# --- Database（本地）---
POSTGRES_URL=postgresql://postgres:lingsi123@localhost:5432/lingsi

# --- App ---
NEXT_PUBLIC_API_URL=http://localhost:8000
